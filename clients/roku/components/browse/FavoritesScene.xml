<?xml version="1.0" encoding="utf-8" ?>
<!--
    Favorites — items the user has heart-clicked from any detail
    page. Read-only RowList of poster cards; clicking a card
    routes through routeForType so containers go to DetailScene
    and leaves go straight to the player. Same shape the Android
    FavoritesFragment ships.
-->
<component name="FavoritesScene" extends="Group">

    <script type="text/brightscript" uri="FavoritesScene.brs" />
    <script type="text/brightscript" uri="pkg:/source/util/Prefs.brs" />
    <script type="text/brightscript" uri="pkg:/source/api/Endpoints.brs" />

    <children>
        <Group translation="[0,0]" width="1920" height="1080">
            <Rectangle width="1920" height="1080" color="0x121212ff" />

            <Label id="title"
                   text="Favorites"
                   translation="[80, 50]"
                   font="font:LargeBoldSystemFont"
                   color="0xffffffff" />

            <RowList id="rows"
                     translation="[80, 160]"
                     itemComponentName="PosterCard"
                     itemSize="[1760, 380]"
                     rowItemSize="[[240, 360]]"
                     rowItemSpacing="[[20, 0]]"
                     showRowLabel="[false]"
                     rowHeights="[380]"
                     focusBitmapBlendColor="0xffffffff"
                     drawFocusFeedback="true" />

            <Label id="empty"
                   text="Heart-click an item from its detail page to pin it here."
                   translation="[80, 540]"
                   color="0xa0a0a0ff" />
        </Group>

        <ListFetchTask id="task" />
    </children>

</component>
