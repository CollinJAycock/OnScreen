<?xml version="1.0" encoding="utf-8" ?>
<!--
    Task that POSTs /api/v1/items/{id}/transcode and writes the
    server's session response back. PlayerScene fires it when
    Playback_Decide returns mode=remux or mode=transcode; on
    completion the task's `result` carries { session_id,
    playlist_url, token } which the scene weaves into the HLS
    URL handed to the Video node.

    Distinct from ItemFetchTask so the two requests can fire in
    parallel — the item fetch has the file metadata we need to
    decide the mode, but once decided the transcode start +
    Video node prep can race the rest of the item-detail load.
-->
<component name="TranscodeStartTask" extends="Task">

    <interface>
        <field id="itemId" type="string" />
        <field id="fileId" type="string" />
        <field id="height" type="integer" />
        <field id="videoCopy" type="boolean" />
        <field id="supportsHevc" type="boolean" />
        <!-- audio_stream_index is an optional re-issue param. -1
             means "use server default" (the standard first run);
             non-negative is the index from item.files[0].audio_streams
             that the user picked from the in-player Audio picker.
             positionMs lets a re-issue resume at the exact second
             instead of restarting from 0. -->
        <field id="audioStreamIndex" type="integer" value="-1" />
        <field id="positionMs" type="integer" value="0" />
        <field id="result" type="assocArray" />
    </interface>

    <script type="text/brightscript" uri="TranscodeStartTask.brs" />
    <script type="text/brightscript" uri="pkg:/source/api/Client.brs" />
    <script type="text/brightscript" uri="pkg:/source/api/Endpoints.brs" />
    <script type="text/brightscript" uri="pkg:/source/util/Json.brs" />
    <script type="text/brightscript" uri="pkg:/source/util/Prefs.brs" />

</component>
