<?xml version="1.0" encoding="utf-8" ?>
<!--
    Video playback scene. Wraps the firmware Video node, which
    handles HLS / DASH / direct-play file streaming, audio + sub
    selection, transport state, and the on-screen controls
    natively. We feed it a ContentNode with the stream URL + a
    handful of metadata fields (title, runtime, etc.).

    Item resolution (item id → file id → playback decision)
    happens in a Task node so the UI thread stays responsive
    while we hit the item endpoint. A second Task starts the
    server-side ffmpeg session when the decision says
    remux / transcode (HLS), and is skipped on direct play
    (the file streams as-is via /media/stream/{id}).

    Three more tasks ride alongside for player polish:
      - markersTask: /items/{id}/markers, drives Skip Intro /
        Skip Credits overlay
      - childrenTask: /items/{parent}/children, used to pick
        the next sibling for music auto-advance + the Up Next
        overlay between episodes
      - syncTimer: polls /items/{id} while paused so a position
        update from another logged-in device snaps this player
        to the new offset (Roku has no native SSE consumer, so
        polling is the practical equivalent)
-->
<component name="PlayerScene" extends="Group">

    <interface>
        <field id="itemId" type="string" />
    </interface>

    <script type="text/brightscript" uri="PlayerScene.brs" />
    <script type="text/brightscript" uri="pkg:/source/util/Prefs.brs" />
    <script type="text/brightscript" uri="pkg:/source/api/Client.brs" />
    <script type="text/brightscript" uri="pkg:/source/api/Endpoints.brs" />
    <script type="text/brightscript" uri="pkg:/source/util/Json.brs" />
    <script type="text/brightscript" uri="pkg:/source/playback/Decide.brs" />

    <children>
        <Video id="video"
               width="1920"
               height="1080"
               translation="[0,0]" />

        <!-- Skip Intro / Skip Credits overlay. Visible while the
             playhead is inside an active marker window; the user
             presses * (the convention for Roku channel "options"
             actions) to skip. Stays hidden otherwise. -->
        <Label id="skipMarker"
               text=""
               translation="[1500, 940]"
               width="380"
               height="80"
               horizAlign="center"
               vertAlign="center"
               color="0xffffffff"
               backgroundColor="0x7c6af7ee"
               backgroundUri=""
               visible="false" />

        <!-- Up Next overlay. Surfaces ~25 s before EOS for episodes
             and podcast episodes. Music tracks + audiobook chapters
             chain silently at EOS instead — no overlay because the
             closing seconds carry the outro / final line. -->
        <Group id="upNext"
               translation="[1380, 60]"
               visible="false">
            <Rectangle width="500" height="160" color="0x07070dee" />
            <Label id="upNextLabel"
                   text="UP NEXT"
                   translation="[20, 16]"
                   color="0x7c6af7ff"
                   font="font:SmallBoldSystemFont" />
            <Label id="upNextTitle"
                   text=""
                   translation="[20, 56]"
                   width="460"
                   color="0xffffffff"
                   font="font:MediumBoldSystemFont"
                   wrap="true"
                   maxLines="2" />
            <Label id="upNextHint"
                   text="OK to play now"
                   translation="[20, 124]"
                   color="0x9a9aaaff"
                   font="font:SmallSystemFont" />
        </Group>

        <!-- In-player Audio + Subtitle picker. The * (options) button
             toggles the panel through three states: closed → audio
             open → subtitle open → closed. up/down navigates the
             list, OK selects, back closes. Hidden by default; the
             Video node keeps focus during normal playback. -->
        <Group id="trackPicker"
               translation="[1380, 200]"
               visible="false">
            <Rectangle width="500" height="640" color="0x07070dee" />
            <Label id="trackPickerTitle"
                   text=""
                   translation="[24, 18]"
                   color="0x9a9aaaff"
                   font="font:SmallBoldSystemFont" />
            <LabelList id="trackPickerList"
                       translation="[16, 56]"
                       itemSize="[468, 52]"
                       numRows="11"
                       drawFocusFeedback="true"
                       focusBitmapBlendColor="0x7c6af7ff" />
        </Group>

        <ItemFetchTask id="itemTask" />
        <TranscodeStartTask id="transcodeTask" />
        <ListFetchTask id="markersTask" />
        <ListFetchTask id="childrenTask" />

        <!-- Cross-device resume sync. Roku has no native SSE
             primitive, so we poll /items/{id} every 5 s while
             paused and snap to view_offset_ms when it diverges
             from local. Active local playback wins — the polled
             update is ignored on a playing player. -->
        <Timer id="syncTimer" duration="5" repeat="true" />
    </children>

</component>
