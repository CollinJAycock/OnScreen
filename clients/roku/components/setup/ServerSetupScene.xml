<?xml version="1.0" encoding="utf-8" ?>
<!--
    First-run server URL picker. Renders the Roku built-in
    `Keyboard` node (full on-screen QWERTY) bound to a label
    showing the URL being typed, plus a "Connect" button that
    probes the URL for OnScreen's /health/live before persisting it.

    Bad URLs surface inline as a red label so the user can correct
    without losing what they typed.
-->
<component name="ServerSetupScene" extends="Group">

    <script type="text/brightscript" uri="ServerSetupScene.brs" />
    <script type="text/brightscript" uri="pkg:/source/util/Prefs.brs" />
    <script type="text/brightscript" uri="pkg:/source/api/Client.brs" />
    <script type="text/brightscript" uri="pkg:/source/api/Endpoints.brs" />
    <script type="text/brightscript" uri="pkg:/source/util/Json.brs" />

    <children>
        <Group translation="[0,0]" width="1920" height="1080">
            <Rectangle width="1920" height="1080" color="0x1a1a1aff" />

            <Label id="title"
                   text="Connect to OnScreen"
                   translation="[160, 120]"
                   font="font:LargeBoldSystemFont"
                   color="0xffffffff" />

            <Label id="hint"
                   text="Enter the URL of your OnScreen server (e.g. http://192.168.1.50:7070)"
                   translation="[160, 200]"
                   color="0xa0a0a0ff" />

            <Keyboard id="keyboard"
                      translation="[160, 280]"
                      width="1600"
                      showTextEditBox="true" />

            <Button id="connectBtn"
                    text="Connect"
                    translation="[160, 720]"
                    minWidth="320" />

            <Label id="error"
                   translation="[160, 800]"
                   color="0xff5050ff"
                   visible="false" />
        </Group>
    </children>

</component>
