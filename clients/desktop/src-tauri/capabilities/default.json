{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the OnScreen desktop window. Grants the IPC bridge to the commands the scaffold exposes plus the store plugin used to persist server URL / credentials.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:tray:allow-new",
    "core:tray:allow-set-icon",
    "core:tray:allow-set-tooltip",
    "core:tray:allow-set-visible",
    "core:tray:allow-set-menu",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-unminimize",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-delete",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-is-registered",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission"
  ]
}
