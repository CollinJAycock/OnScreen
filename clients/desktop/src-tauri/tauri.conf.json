{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OnScreen",
  "version": "0.1.0",
  "identifier": "com.onscreen.desktop",
  "build": {
    "frontendDist": "../../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "OnScreen",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Entertainment",
    "shortDescription": "OnScreen media client",
    "longDescription": "Native desktop client for the OnScreen media server. Audiophile-grade playback (bit-perfect, gapless) and full feature parity with the web UI."
  }
}
