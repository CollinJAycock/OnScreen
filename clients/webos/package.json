{
  "name": "onscreen-webos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 5174",
    "build": "vite build && node scripts/assemble-package.mjs",
    "preview": "vite preview --host 0.0.0.0 --port 5174",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "package": "npm run build && ares-package build",
    "install-tv": "ares-install --device tv ./com.onscreen.tv_*.ipk",
    "launch-tv": "ares-launch --device tv com.onscreen.tv",
    "inspect-tv": "ares-inspect --device tv --app com.onscreen.tv"
  },
  "dependencies": {
    "hls.js": "^1.5.15"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
