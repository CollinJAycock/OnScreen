<?xml version="1.0" encoding="utf-8"?>
<!--
    Stateful selector that paints the focus ring only when the card has
    keyboard / D-pad focus. Plain transparent rectangle in the unfocused
    state keeps the poster art clean.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true" android:drawable="@drawable/card_focus_ring" />
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
