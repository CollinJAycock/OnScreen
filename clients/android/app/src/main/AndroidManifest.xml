<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- WAKE_LOCK lets ExoPlayer hold a CPU wake lock during playback
         (setWakeMode(WAKE_MODE_LOCAL) in PlaybackFragment). The
         screen-on flag is window-level and doesn't need a permission. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Lets WatchNextManager publish + remove rows in the system's
         WatchNextPrograms content provider so resumable items show
         up in Google TV's "Continue Watching" row across launchers
         (TV-PN quality compliance). The READ permission is only
         needed when querying for our own existing rows; without it
         we'd insert duplicate entries on every progress tick. -->
    <uses-permission android:name="com.android.providers.tv.permission.WRITE_EPG_DATA" />
    <uses-permission android:name="com.android.providers.tv.permission.READ_EPG_DATA" />

    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false" />
    <!-- Amazon Fire TV runs Fire OS (an Android fork) and accepts
         the same APK as Google TV. This feature declaration is
         what Amazon's launcher reads to classify the app under
         the TV category in the Amazon Appstore; on a stock
         Android TV / Google TV device it's an unknown feature
         and ignored (required="false" makes it a no-op there).
         See clients/firetv/README.md for the Fire TV-specific
         build / sideload / store-submission workflow. -->
    <uses-feature
        android:name="amazon.hardware.fire_tv"
        android:required="false" />

    <application
        android:name=".OnScreenApp"
        android:allowBackup="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:banner="@drawable/ic_banner_art"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.OnScreen">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:supportsPictureInPicture="true"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation|keyboardHidden|keyboard|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
            <!-- Deep-link entry point. Watch Next launcher tiles
                 publish onscreen://watch/<item_id>?position=<ms>
                 URIs; MainActivity reads the path + query in
                 onCreate / onNewIntent and routes straight into
                 PlaybackFragment with a resume offset. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="onscreen" android:host="watch" />
            </intent-filter>
        </activity>

        <!-- MediaSessionService: hosts ExoPlayer when audio playback
             continues outside the PlaybackFragment so navigating to
             another screen doesn't stop music. PlaybackFragment binds
             via MediaController; the service owns the player. -->
        <service
            android:name=".playback.OnScreenMediaSessionService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>
    </application>
</manifest>
