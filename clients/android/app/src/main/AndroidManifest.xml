<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- WAKE_LOCK lets ExoPlayer hold a CPU wake lock during playback
         (setWakeMode(WAKE_MODE_LOCAL) in PlaybackFragment). The
         screen-on flag is window-level and doesn't need a permission. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false" />
    <!-- Amazon Fire TV runs Fire OS (an Android fork) and accepts
         the same APK as Google TV. This feature declaration is
         what Amazon's launcher reads to classify the app under
         the TV category in the Amazon Appstore; on a stock
         Android TV / Google TV device it's an unknown feature
         and ignored (required="false" makes it a no-op there).
         See clients/firetv/README.md for the Fire TV-specific
         build / sideload / store-submission workflow. -->
    <uses-feature
        android:name="amazon.hardware.fire_tv"
        android:required="false" />

    <application
        android:name=".OnScreenApp"
        android:allowBackup="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:banner="@drawable/ic_banner_art"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.OnScreen">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
