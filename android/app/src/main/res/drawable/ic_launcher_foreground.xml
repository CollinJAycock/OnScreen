<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon foreground. The logo PNG has its own dark letterboxing
    baked in (~24% padding top/bottom), which already keeps the visible
    artwork inside the 72dp safe zone of the 108dp canvas, so no extra
    inset is needed here.
-->
<bitmap xmlns:android="http://schemas.android.com/apk/res/android"
    android:src="@drawable/ic_logo"
    android:gravity="fill" />
