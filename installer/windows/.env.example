# OnScreen Windows test deployment — config template.
# Copy this file to `.env` (same directory) and edit for your box.

# ── Required ─────────────────────────────────────────────────────────────────

# Postgres connection. The bundled docker-compose.deps.yml exposes
# 5432 with these credentials by default.
DATABASE_URL="postgres://onscreen:onscreen@localhost:5432/onscreen?sslmode=disable"

# Valkey/Redis connection. The bundled docker-compose.deps.yml exposes
# 6379 with no auth.
VALKEY_URL="redis://localhost:6379"

# 32-byte secret used for JWT signing + token encryption. Generate fresh:
#   PowerShell:  -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 32 | ForEach-Object {[char]$_})
# Anything 32+ chars works; longer is fine.
SECRET_KEY="REPLACE-ME-32-RANDOM-BYTES-XXXXXXX"

# ── Where your media lives ───────────────────────────────────────────────────

# Root path that `Library` rows in the admin UI will be allowed to scan
# beneath. Use forward slashes or escaped backslashes.
MEDIA_PATH="C:/media"

# ── Optional ─────────────────────────────────────────────────────────────────

# Extra dirs prepended to PATH at startup (semicolon-separated). The
# bundled ffmpeg dir is added automatically; only set this if you have
# additional binaries (fpcalc, etc.) somewhere else.
# TOOLS_PATH="C:/libs"

# Logging level: debug | info | warn | error.
LOG_LEVEL="info"

# Public origin used for absolute URL generation (notifications,
# OAuth callbacks, magic-link emails). Leave unset for localhost-only
# testing.
# PUBLIC_BASE_URL="https://onscreen.example.com"

# TMDB v3 API key for movie/TV metadata enrichment (cover art, ratings,
# genres, certifications). Free key: https://www.themoviedb.org/settings/api
# TMDB_API_KEY=""

# Transcode resource caps. Leave unset for full UHD ladder defaults.
# TRANSCODE_MAX_BITRATE_KBPS=40000
# TRANSCODE_MAX_WIDTH=3840
# TRANSCODE_MAX_HEIGHT=2160

# Hot-reloadable NVENC tuning (irrelevant on this Intel box but kept
# for documentation parity with the dev .env).
# TRANSCODE_NVENC_PRESET=p4
# TRANSCODE_NVENC_TUNE=hq
# TRANSCODE_NVENC_RC=vbr
