# OnScreen Linux test deployment — config template.
# Copy this file to `.env` (same directory) and edit for your box.

# ── Required ─────────────────────────────────────────────────────────────────

# Postgres connection. The bundled docker-compose.deps.yml exposes
# 5432 with these credentials by default.
DATABASE_URL="postgres://onscreen:onscreen@localhost:5432/onscreen?sslmode=disable"

# Valkey/Redis connection. The bundled docker-compose.deps.yml exposes
# 6379 with no auth.
VALKEY_URL="redis://localhost:6379"

# 32-byte secret used for JWT signing + token encryption. Generate fresh:
#   openssl rand -base64 32
# Anything 32+ chars works; longer is fine.
SECRET_KEY="REPLACE-ME-32-RANDOM-BYTES-XXXXXXX"

# ── Where your media lives ───────────────────────────────────────────────────

# Root path that `Library` rows in the admin UI will be allowed to scan
# beneath. Use absolute paths (no shell expansion).
MEDIA_PATH="/srv/media"

# ── Optional ─────────────────────────────────────────────────────────────────

# Extra dirs prepended to PATH at startup (colon-separated). The
# bundled ffmpeg dir is added automatically; only set this if you have
# additional binaries (fpcalc, etc.) somewhere else.
# TOOLS_PATH="/opt/tools/bin"

# Logging level: debug | info | warn | error.
LOG_LEVEL="info"

# Public origin used for absolute URL generation (notifications,
# OAuth callbacks, magic-link emails). Leave unset for localhost-only
# testing.
# PUBLIC_BASE_URL="https://onscreen.example.com"

# TMDB v3 API key for movie/TV metadata enrichment (cover art, ratings,
# genres). Get one free at https://www.themoviedb.org/settings/api.
# TMDB_API_KEY=""

# TVDB v4 API key (optional — TMDB covers most TV).
# TVDB_API_KEY=""

# ── HTTPS (optional) ─────────────────────────────────────────────────────────

# Operator-provided PEM cert + key. If both are set, the server listens
# on TLS_LISTEN_ADDR (default :7443) instead of LISTEN_ADDR (default :7070).
# TLS_CERT_FILE="/etc/onscreen/tls/fullchain.pem"
# TLS_KEY_FILE="/etc/onscreen/tls/privkey.pem"
# TLS_LISTEN_ADDR=":7443"

# ── GPU transcoding ──────────────────────────────────────────────────────────

# The bundled ffmpeg includes NVENC, VAAPI, libx264, libsvtav1. Detection
# runs at startup and picks the best available encoder per source codec.
#
# For NVIDIA: install the proprietary driver + cuda-runtime; the static
# ffmpeg dlopens libcuda.so.1 + libnvidia-encode.so.1 at runtime.
#
# For Intel/AMD VAAPI: install libva2 + the vendor's vaapi driver
# (intel-media-driver / mesa-va-drivers). Verify:  vainfo
#
# Override via the admin UI (Settings → Transcode → Encoders) or with:
# TRANSCODE_ENCODERS="h264_nvenc,hevc_nvenc,libx264"
