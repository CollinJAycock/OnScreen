# OnScreen configuration
# Copy to .env and adjust values for your setup.
# Required variables are marked with (required).

# ── Required ─────────────────────────────────────────────────────────────────
export DATABASE_URL="postgres://onscreen:onscreen@localhost:5432/onscreen?sslmode=disable"  # (required)
export VALKEY_URL="redis://localhost:6379"      # (required)
export SECRET_KEY="change-me-to-a-random-32-byte-string"  # (required) AES-256 key: hex (64 chars), base64 (~44 chars), or raw (32+ bytes)

# ── Database (optional) ──────────────────────────────────────────────────────
# Read-only replica URL. Falls back to DATABASE_URL if unset (single-node).
# export DATABASE_RO_URL="postgres://onscreen:onscreen@readonly-host:5432/onscreen?sslmode=disable"

# ── Server ───────────────────────────────────────────────────────────────────
# export LISTEN_ADDR=":7070"       # API listen address (default :7070)
# export METRICS_ADDR=":7071"      # Prometheus metrics (default :7071)
# export LOG_LEVEL="info"          # debug, info, warn, error (default info)
# export RETAIN_MONTHS="24"        # Audit log retention in months (default 24)
# export BASE_URL="https://media.example.com"  # Public URL; required for OAuth redirects

# ── Media ────────────────────────────────────────────────────────────────────
# Deprecated: artwork is now stored next to media files. Only needed if you
# store artwork in a separate directory.
# export MEDIA_PATH="/path/to/your/media"
# export CACHE_PATH="/path/to/artwork/cache"  # Defaults to $MEDIA_PATH/.cache/artwork

# ── Scanning ─────────────────────────────────────────────────────────────────
# export SCAN_FILE_CONCURRENCY="0"          # 0 = auto (NumCPU * 2, I/O-bound)
# export SCAN_LIBRARY_CONCURRENCY="2"       # Concurrent library scans (default 2)
# export MISSING_FILE_GRACE_PERIOD="15m"    # Grace period before marking files missing

# ── Transcoding ──────────────────────────────────────────────────────────────
# export TRANSCODE_MAX_SESSIONS="0"         # 0 = auto (NumCPU/2 for software, 4 for hardware)
# export TRANSCODE_ENCODERS=""              # Override auto-detect: "nvenc,software", "vaapi", "software"
# export TRANSCODE_MAX_BITRATE_KBPS="40000" # Max output bitrate (default 40 Mbps)
# export TRANSCODE_MAX_WIDTH="3840"         # Max output width (default 3840)
# export TRANSCODE_MAX_HEIGHT="2160"        # Max output height (default 2160)
#
# ── Encoder tuning (hot-reloadable via SIGHUP) ──────────────────────────────
# Fine-tune FFmpeg encoding parameters for your GPU model and network bandwidth.
# Most users should leave these at defaults. Change only if you understand the
# FFmpeg encoder options for your hardware.
#
# NVENC preset controls speed vs quality trade-off. Lower = faster, higher = better.
#   p1 (fastest) → p2 → p3 → p4 (balanced) → p5 → p6 → p7 (best quality)
# export TRANSCODE_NVENC_PRESET="p4"
#
# NVENC tune optimizes for a specific use case:
#   hq  — high quality (recommended for VOD/media server)
#   ll  — low latency (live streaming, screen share)
#   ull — ultra-low latency (game streaming, real-time)
# export TRANSCODE_NVENC_TUNE="hq"
#
# NVENC rate control mode:
#   vbr     — variable bitrate (best quality per bit, recommended)
#   cbr     — constant bitrate (stable bandwidth, less efficient)
#   constqp — constant quantizer (fixed quality, unpredictable file size)
# export TRANSCODE_NVENC_RC="vbr"
#
# Maxrate headroom ratio (applies to ALL encoders, not just NVENC).
# maxrate = bitrate × ratio. Higher values let the encoder handle complex scenes
# (action, grain) without quality drops; lower values cap peak bandwidth.
#   1.0 — strict (maxrate equals target bitrate, may drop quality on complex scenes)
#   1.5 — balanced (default, 50% headroom)
#   2.0 — generous (good for high-bandwidth local networks)
# export TRANSCODE_MAXRATE_RATIO="1.5"

# ── Metadata (optional) ─────────────────────────────────────────────────────
# export TMDB_API_KEY="your-tmdb-api-v3-key"         # Enables movie/TV metadata + artwork
# export TMDB_RATE_LIMIT="5"                          # TMDB API requests/sec (default 5)
# export TVDB_API_KEY="your-tvdb-v4-project-key"      # Enables episode metadata fallback

# ── Worker ──────────────────────────────────────────────────────────────────
# export WORKER_HEALTH_ADDR=":7074"   # Worker health server (/health/live, /health/ready)

# ── Observability ────────────────────────────────────────────────────────────
# export OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"  # OpenTelemetry collector

# ── OAuth / SSO (optional) ───────────────────────────────────────────────────
# Requires BASE_URL to be set for redirect URIs.
# export GOOGLE_CLIENT_ID=""
# export GOOGLE_CLIENT_SECRET=""
# export GITHUB_CLIENT_ID=""
# export GITHUB_CLIENT_SECRET=""
# export DISCORD_CLIENT_ID=""
# export DISCORD_CLIENT_SECRET=""

# ── Email / SMTP (optional) ─────────────────────────────────────────────────
# All four values required to enable email (password reset, invites).
# export SMTP_HOST="smtp.gmail.com"
# export SMTP_PORT="587"
# export SMTP_USERNAME=""
# export SMTP_PASSWORD=""
# export SMTP_FROM="OnScreen <noreply@example.com>"

# ── Development ──────────────────────────────────────────────────────────────
# export DEV_FRONTEND_URL="http://localhost:5173"  # Proxy to Vite dev server (dev builds only)
