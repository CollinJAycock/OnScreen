# OnScreen — bootstrap configuration
#
# Copy to .env, fill in the required values, then run the server.
#
# Anything that can be configured at runtime lives in the admin Settings UI at
# /settings — TMDB / TVDB keys, transcode tuning, OIDC, LDAP, OpenSubtitles,
# SMTP, webhooks, scheduled tasks, worker fleet, OpenTelemetry tracing,
# the public base URL, log level, and CORS allow-list.
#
# What remains here is the irreducible bootstrap set: things needed to open
# the database, bind HTTP listeners, or decrypt settings before the UI exists.

# ── Required ─────────────────────────────────────────────────────────────────
export DATABASE_URL="postgres://onscreen:onscreen@localhost:5432/onscreen?sslmode=disable"
export VALKEY_URL="redis://localhost:6379"
export SECRET_KEY="change-me-to-a-random-32-byte-string"  # AES-256: hex (64), base64 (~44), or raw 32+ bytes

# ── Bind addresses & infrastructure ──────────────────────────────────────────
# These have to be set before the process can listen on a socket or open a
# read-replica pool, so they can't move into the UI.
# export DATABASE_RO_URL="postgres://...@readonly:5432/onscreen?sslmode=disable"  # falls back to DATABASE_URL
# export LISTEN_ADDR=":7070"
# export METRICS_ADDR=":7071"
# export WORKER_HEALTH_ADDR=":7074"                        # worker binary only

# ── Development ──────────────────────────────────────────────────────────────
# export DEV_FRONTEND_URL="http://localhost:5173"          # proxy to Vite (dev builds only)
