# OnScreen development environment
# Copy to .env.dev and adjust values for your setup.
export DATABASE_URL="postgres://onscreen:onscreen@localhost:5432/onscreen?sslmode=disable"
export VALKEY_URL="redis://localhost:6379"
export MEDIA_PATH="/path/to/your/media"
export SECRET_KEY="change-me-to-a-random-32-byte-string"
export LOG_LEVEL=debug

# ── Metadata (optional) ──────────────────────────────────────────────────
# export TMDB_API_KEY="your-tmdb-api-v3-key"
# export TVDB_API_KEY="your-tvdb-v4-project-key"

# ── OAuth / SSO (optional) ───────────────────────────────────────────────
# export BASE_URL="http://localhost:7070"
# export GOOGLE_CLIENT_ID=""
# export GOOGLE_CLIENT_SECRET=""
# export GITHUB_CLIENT_ID=""
# export GITHUB_CLIENT_SECRET=""
# export DISCORD_CLIENT_ID=""
# export DISCORD_CLIENT_SECRET=""

