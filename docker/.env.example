# OnScreen Docker environment variables
# Copy to .env and fill in values before running docker compose up.

# Required — AES-256 key (32+ bytes, hex-encoded 64 chars, or base64 ~44 chars)
SECRET_KEY=change-me-generate-with-openssl-rand--hex-32

# Database password for the onscreen PostgreSQL user
DB_PASS=onscreen

# TMDB API key for metadata enrichment (cover art, ratings, genres)
# Obtain from https://www.themoviedb.org/settings/api
# Optional here — can also be set from the admin Settings UI.
TMDB_API_KEY=
